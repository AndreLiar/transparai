# Environment Configuration Example
# Copy this file to .env and fill in your actual values

# Node Environment
NODE_ENV=development
PORT=5000

# Database Configuration
# Production: auto-populated from Azure Cosmos DB for MongoDB (see infra/main.tf)
# Local dev: use a local MongoDB instance or Cosmos DB emulator
MONGO_URI=mongodb://localhost:27017/transparai

# Firebase Configuration
# Use the full JSON service account in production
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"your-project-id","private_key":"your-private-key","client_email":"your-client-email"}

# Azure AI Foundry (LLM provider for all plans — gpt-4o-mini for free/standard, gpt-4o for premium/enterprise)
# Get these from: Azure Portal → AI Foundry → your project → deployments
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your_azure_openai_key_here
AZURE_OPENAI_API_VERSION=2024-08-01-preview
AZURE_OPENAI_DEPLOYMENT_GPT4O=gpt-4o
AZURE_OPENAI_DEPLOYMENT_GPT4O_MINI=gpt-4o-mini

# Direct OpenAI (local dev only — not used if Azure is configured)
OPENAI_API_KEY=your_openai_api_key_here
# Voyage AI — legal-domain embeddings for MongoDB Atlas Vector Search (RAG)
# Free tier: 200M tokens/month — https://dash.voyageai.com
VOYAGE_API_KEY=your_voyage_api_key_here

# Stripe Configuration
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Frontend URL
FRONTEND_URL=http://localhost:5173

# Security Configuration
JWT_SECRET=your_jwt_secret_at_least_32_characters_long
ENCRYPTION_KEY=your_encryption_key_at_least_32_chars
SESSION_SECRET=your_session_secret_at_least_32_chars

# Logging
LOG_LEVEL=info

# Monitoring — Azure Application Insights (provisioned via Terraform — infra/main.tf)
# Injected automatically into App Service env by Terraform.
# For local dev: get the value from Azure Portal → Application Insights → Overview → Connection String
# Leave empty to disable (safe for local dev)
APPLICATIONINSIGHTS_CONNECTION_STRING=